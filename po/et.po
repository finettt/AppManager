#: data/com.github.AppManager.metainfo.xml:6
#: data/com.github.AppManager.metainfo.xml:8
msgid "Arnis Kemlers"
msgstr "Arnis Kemlers"

#: data/com.github.AppManager.metainfo.xml:9
msgid "Drag-and-drop AppImage installer for GNOME"
msgstr "Drag-and-drop AppImage installer GNOME jaoks"

#: data/com.github.AppManager.metainfo.xml:35
msgid ""
"AppManager lets you install or uninstall AppImages with a familiar drag-and-"
"drop workflow inspired by macOS. It handles desktop integration, icon "
"extraction, executable bits, and Nautilus context menus."
msgstr ""
"AppManager võimaldab teil installida või desinstallida AppImages, kasutades "
"tuttavat macOS-ist inspireeritud pukseerimise töövoogu. See tegeleb töölaua "
"integreerimise, ikooni ekstraheerimise, käivitatavate bittide ja Nautiluse "
"kontekstimenüüdega."
